{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=your_db_name;User=root;Password=your_password;CharSet=utf8mb4;"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_JWT_KEY_MINIMUM_32_CHARS",
    "Issuer": "FamiHub",
    "Audience": "FamiHubApp"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Seaweed": {
    "MasterUrl": "http://localhost:9333",
    "PublicUrl": "http://localhost:8080",
    "VolumeUrlOverride": "http://localhost:8080"
  },
  "Cloudinary": {
    "CloudName": "your_cloud_name",
    "ApiKey": "your_api_key",
    "ApiSecret": "your_api_secret"
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUser": "your_email@gmail.com",
    "SmtpPass": "your_app_password",
    "FromName": "FamiHub"
  },
  "PayOS": {
    "ClientId": "your_payos_client_id",
    "ApiKey": "your_payos_api_key",
    "ChecksumKey": "your_payos_checksum_key"
  },
  "GeminiAI": {
    "ApiKey": "your_gemini_api_key",
    "Model": "gemini-2.5-flash",
    "MaxTokens": "8192"
  }
}
